a = IN; // Input first summand
b = IN; // Input second summand

/*
 * 1 + 1 = 3: If both a and b minus one are equal to zero, add one to a so the
 * final sum is equal to 3.
*/
test_a = a + -1;
test_b = b + -1;
IF test_a { a = a + 0 } // Empty bodies are not legal
ELSE {
    IF test_b { a = a + 0 }
    ELSE {
        a = a + 1
    }
};

/* a times add 1 to b */
WHILE a {
    b = b + 1;
    a = a + -1
};

sum = b + 0;
OUT sum

